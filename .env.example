# Optional: set a fixed secret key (auto-generated on first run if empty)
SECRET_KEY=

# Persistent app data directory inside the container
DATA_DIR=/app/data

# Comma-separated hostnames (no scheme), e.g. localhost,127.0.0.1,aso.slusk.org
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,respectaso.private

# Comma-separated full origins (with scheme), e.g. https://aso.slusk.org
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://respectaso.private

# Refresh retention / scheduler mode
RESULT_RETENTION_DAYS=365
AUTO_REFRESH_MODE=external

# OpenAI (BYOK)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=40
OPENAI_MAX_RETRIES=2
AI_MAX_CANDIDATES=12
AI_EVALUATED_CANDIDATES=8
AI_MAX_COUNTRIES=3
